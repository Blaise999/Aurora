# AuroraNft — Environment Variables
# Copy to .env.local and fill in your values

# ─── Alchemy ────────────────────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key

# ─── Chain ──────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── Smart Contracts ────────────────────────────────────────
NEXT_PUBLIC_AURORA_CONTRACT=0x_your_aurora_contract
NEXT_PUBLIC_BUY_COLLECTOR_CONTRACT=0x_your_buy_collector
NEXT_PUBLIC_TREASURY_WALLET=0x_your_treasury_wallet

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Session / Auth ─────────────────────────────────────────
SESSION_SECRET=your_session_secret_at_least_16_chars

# ─── ntfy Push Notifications ────────────────────────────────
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=aurora-nft-admin
# NTFY_AUTH_TOKEN=tk_your_token

# ─── WalletConnect (optional) ───────────────────────────────
NEXT_PUBLIC_WC_PROJECT_ID=your_wc_project_id

# ─── Base RPC (for mint confirm) ────────────────────────────
BASE_RPC_URL=https://sepolia.base.org
